@startuml
skinparam packageStyle rectangle

title Unified Domain Class Diagram - Restaurant + Security + InternControl

' =========================
' Restaurant bounded context
' =========================
package "Restaurant" {
    package "Domain" {
        package "Model" {
            package "Aggregates" {
                class Organization <<AggregateRoot>> {
                    -OrganizationId id
                    -Organization organization
                }
                class User <<AggregateRoot>> {
                    -UserId id
                    -Identity identity
                    -List<Permission> permissions
                }
            }
            package "Entities" {
                class Organization <<Entity>> {
                    -OrganizationId id
                    -OrganizationName name
                    -UserId organizationOwner
                    -RestaurantCoordinates coordinates
                    -LocationReferences references
                }
                class Identity <<Entity>> {
                    -UserId id
                    -FullName fullName
                    -Email email
                    -UserType type
                    -OrganizationId organizationId
                }
            }
            package "Commands" {
                class CreateOrganizationCommand
                class CreateUserCommand
                class ConfigureUserPermissionsCommand
            }
            package "Queries" {
                class GetOrganizationByIdQuery
                class GetUserByIdQuery
                class ListUsersByOrganizationQuery
            }
            package "ValueObjects" {
                class OrganizationId <<ValueObject>> {
                    -Int id
                }
                class UserId <<ValueObject>> {
                    -Int id
                }
                class Email <<ValueObject>> {
                    -String value
                }
                class FullName <<ValueObject>> {
                    -String value
                }
                class OrganizationName <<ValueObject>> {
                    -String value
                }
                class RestaurantCoordinates <<ValueObject>> {
                    -Decimal latitude
                    -Decimal longitude
                }
                class LocationReferences <<ValueObject>> {
                    -List<String> values
                }
                enum UserType <<ValueObject>> {
                    TENIENTE
                    ENCARGADO
                }
                class Permission <<ValueObject>> {
                    -Int id
                    -String permissionName
                }
            }
        }
        package "Services" {
            package "CommandServices" {
                class OrganizationCommandService <<DomainService>>
                class UserCommandService <<DomainService>> {
                    +createUser(type: UserType, permissions: List<Permission>): User
                    +configurePermissions(userId: UserId, permissions: List<Permission>)
                }
            }
            package "QueryServices" {
                class OrganizationQueryService <<DomainService>>
                class UserQueryService <<DomainService>>
            }
        }
    }
}

