title Restaurant - Application Layer Structure

package "Restaurant" {
    package "Domain" {
        package "Model" {
            package "Aggregates" {}
            package "Commands" {}
            package "Queries" {}
        }
        package "Services" {}
    }

    package "Application.Internal" {
        package "CommandServices" {
            class OrganizationCommandApplicationService <<ApplicationService>> {
                +handleCreateOrganization(command): void
                +handleUpdateOrganization(command): void
            }
            class UserCommandApplicationService <<ApplicationService>> {
                +handleCreateUser(command): void
                +handleConfigurePermissions(command): void
            }
        }
        package "QueryServices" {
            class OrganizationQueryApplicationService <<ApplicationService>> {
                +handleGetOrganizationById(query)
                +handleListOrganizations(query)
            }
            class UserQueryApplicationService <<ApplicationService>> {
                +handleGetUserById(query)
                +handleListUsersByOrganization(query)
            }
        }
    }

    package "Infrastructure.Persistence" {
        package "JPA" {
            class OrganizationRepository <<Repository>> {
                +save(organization): void
                +findById(id)
            }
            class UserRepository <<Repository>> {
                +save(user): void
                +findById(id)
            }
        }
    }
}

