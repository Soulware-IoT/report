Restaurant.Infrastructure.Persistence.JPA.Repositories.JpaOrganizationRepository ..> Restaurant.Infrastructure.Persistence.JPA.Entities.OrganizationEntity
Restaurant.Infrastructure.Persistence.JPA.Repositories.JpaUserRepository ..> Restaurant.Infrastructure.Persistence.JPA.Entities.UserEntity
Restaurant.Infrastructure.Persistence.JPA.Repositories.JpaUserRepository ..> Restaurant.Infrastructure.Persistence.JPA.Entities.PermissionEntity

Restaurant.Infrastructure.Persistence.JPA.Mappers.OrganizationMapper ..> Restaurant.Domain.Model.Aggregates
Restaurant.Infrastructure.Persistence.JPA.Mappers.UserMapper ..> Restaurant.Domain.Model.Aggregates
Restaurant.Infrastructure.Persistence.JPA.Mappers.OrganizationMapper ..> Restaurant.Domain.Model.ValueObjects
Restaurant.Infrastructure.Persistence.JPA.Mappers.UserMapper ..> Restaurant.Domain.Model.ValueObjects

Restaurant.Application.Internal.CommandServices ..> Restaurant.Infrastructure.Persistence.JPA.Repositories
Restaurant.Application.Internal.QueryServices ..> Restaurant.Infrastructure.Persistence.JPA.Repositories
@enduml
