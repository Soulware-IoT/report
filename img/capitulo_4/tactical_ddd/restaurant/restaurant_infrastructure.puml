@startuml
skinparam packageStyle rectangle

title Restaurant - Infrastructure Layer Structure

package "Restaurant" {
    package "Infrastructure.Persistence" {
        package "JPA" {
            package "Entities" {
                class OrganizationEntity <<JpaEntity>> {
                    +id: long
                    +name: string
                }
                class UserEntity <<JpaEntity>> {
                    +id: long
                    +email: string
                }
                class PermissionEntity <<JpaEntity>> {
                    +id: long
                    +permissionName: string
                }
            }
            package "Mappers" {
                class OrganizationMapper <<Mapper>> {
                    +toDomain(entity)
                    +toEntity(aggregate)
                }
                class UserMapper <<Mapper>> {
                    +toDomain(entity)
                    +toEntity(aggregate)
                }
            }
            package "Repositories" {
                class JpaOrganizationRepository <<JpaRepository>> {
                    +save(entity): void
                    +findById(id)
                }
                class JpaUserRepository <<JpaRepository>> {
                    +save(entity): void
                    +findById(id)
                }
            }
        }
    }

    package "Domain" {
        package "Model" {
            package "Aggregates" {}
            package "ValueObjects" {}
        }
    }

    package "Application.Internal" {
        package "CommandServices" {}
        package "QueryServices" {}
    }
}

