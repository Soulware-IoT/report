@startuml
skinparam packageStyle rectangle

title RestaurantSecurity - Interface Layer Structure

package "RestaurantSecurity" {
    package "Interfaces.Rest" {
        package "Controllers" {
            class SensorController <<Controller>> {
                +registerSensor(resource)
                +getSensorById(id)
            }
            class ActuatorController <<Controller>> {
                +registerActuator(resource)
                +triggerAction(id, resource)
            }
            class RiskPolicyController <<Controller>> {
                +createRiskPolicy(resource)
                +updateThreshold(id, resource)
            }
        }
        package "Transform" {
            class SensorResourceAssembler <<Assembler>> {
                +toResource(aggregate)
                +toEntity(resource)
            }
            class ActuatorResourceAssembler <<Assembler>> {
                +toResource(aggregate)
                +toEntity(resource)
            }
            class RiskPolicyResourceAssembler <<Assembler>> {
                +toResource(aggregate)
                +toEntity(resource)
            }
        }
        package "Resources" {
            class RegisterSensorResource <<Resource>> {
                +deviceName: string
                +macAddress: string
            }
            class RegisterActuatorResource <<Resource>> {
                +deviceName: string
                +actuatorType: string
            }
            class CreateRiskPolicyResource <<Resource>> {
                +policyName: string
                +thresholds: list
            }
            class UpdateRiskThresholdResource <<Resource>> {
                +measurementType: string
                +threshold: decimal
            }
            class SensorResource <<Resource>> {
                +id: number
                +status: string
            }
            class ActuatorResource <<Resource>> {
                +id: number
                +state: string
            }
            class RiskPolicyResource <<Resource>> {
                +id: number
                +thresholdCount: number
            }
            class PagedResponseResource <<Resource>> {
                +items: list
                +total: number
            }
        }
    }

    package "Application.Internal" {
        package "CommandServices" {}
        package "QueryServices" {}
    }

    package "Domain" {
        package "Model" {
            package "Commands" {}
            package "Queries" {}
            package "Aggregates" {}
        }
    }
}

