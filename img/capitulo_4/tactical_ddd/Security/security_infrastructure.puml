@startuml
skinparam packageStyle rectangle

title RestaurantSecurity - Infrastructure Layer Structure

package "RestaurantSecurity" {
    package "Infrastructure.Persistence" {
        package "JPA" {
            package "Entities" {
                class DeviceEntity <<JpaEntity>> {
                    -DeviceId id
                    -DeviceName name
                    -MacAddress macAddress
                    -DeviceStatus status
                }
                class SensorReadingEntity <<JpaEntity>> {
                    -ReadingId id
                    -ReadingValue value
                }
                class ActuatorEntity <<JpaEntity>> {
                    -DeviceId id
                    -DeviceData deviceData
                    -ActuatorType actuatorType
                    -ActionState state
                }
                class RiskPolicyEntity <<JpaEntity>> {
                    -RiskPolicyId id
                    -List<MeasureThreshold> thresholds
                }
                class MeasureThresholdEntity <<JpaEntity>> {
                    -MeasurementType measurementType
                    -Threshold threshold
                    -DeviceId targetActuatorId
                    -ThresholdTrigger trigger
                }
            }
            package "Mappers" {
                class DeviceMapper <<Mapper>> {
                    +toDomain(entity)
                    +toEntity(aggregate)
                }
                class ActuatorMapper <<Mapper>> {
                    +toDomain(entity)
                    +toEntity(aggregate)
                }
                class RiskPolicyMapper <<Mapper>> {
                    +toDomain(entity)
                    +toEntity(aggregate)
                }
            }
            package "Repositories" {
                class JpaDeviceRepository <<JpaRepository>> {
                    +save(entity): void
                    +findById(id)
                }
                class JpaActuatorRepository <<JpaRepository>> {
                    +save(entity): void
                    +findById(id)
                }
                class JpaRiskPolicyRepository <<JpaRepository>> {
                    +save(entity): void
                    +findById(id)
                }
                class JpaMeasureThresholdRepository <<JpaRepository>> {
                    +save(entity): void
                    +findByRiskPolicyId(id)
                }
            }
        }
    }
}

