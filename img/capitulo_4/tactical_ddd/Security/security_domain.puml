@startuml
skinparam packageStyle rectangle

title RestaurantSecurity - Domain Structure

package "RestaurantSecurity" {
    package "Domain" {
        package "Model" {
            package "Aggregates" {
                class Sensor <<AggregateRoot>> {
                    -DeviceId id
                    -DeviceData deviceData
                    -ReadingValue readingValue
                }
                class Actuator <<AggregateRoot>> {
                    -DeviceId id
                    -DeviceData deviceData
                    -ActuatorType actuatorType
                    -ActionState state
                }
                class RiskPolicy <<AggregateRoot>> {
                    -RiskPolicyId id
                    -List<MeasureThreshold> thresholds
                }
            }
            package "Entities" {
                class DeviceData <<Entity>> {
                    -DeviceId id
                    -DeviceName name
                    -MacAddress macAddress
                    -DeviceStatus status
                }
                class MeasureThreshold <<Entity>> {
                    -MeasurementType measurementType
                    -Threshold threshold
                    -DeviceId targetActuatorId
                    -ThresholdTrigger trigger
                }
            }
            package "ValueObjects" {
                class DeviceId <<ValueObject>> {
                    -Int id
                }
                class DeviceName <<ValueObject>> {
                    -String value
                }
                class MacAddress <<ValueObject>> {
                    -String value
                }
                enum DeviceStatus <<ValueObject>> {
                    ONLINE
                    OFFLINE
                }
                class ActuatorType <<ValueObject>> {
                    -String value
                }
                class MeasurementType <<ValueObject>> {
                    -String value
                }
                class RiskPolicyId <<ValueObject>> {
                    -Int id
                }
                class Threshold <<ValueObject>> {
                    -Decimal value
                }
                enum ThresholdTrigger <<ValueObject>> {
                    ABOVE_THRESHOLD
                    BELOW_THRESHOLD
                }
                class ReadingId <<ValueObject>> {
                    -Int id
                }
                class ReadingValue <<ValueObject>> {
                    -Decimal value
                }
                enum ActionState <<ValueObject>> {
                    STANDBY
                    ACTION
                }
            }
        }
        package "Services" {
            package "Builders" {
                class RiskPolicyBuilder <<Builder>> {
                    +withThresholdRule(measurementType: MeasurementType, threshold: Threshold, targetActuatorId: DeviceId, trigger: ThresholdTrigger): RiskPolicyBuilder
                    +build(): RiskPolicy
                }
            }
            package "CommandServices" {
                class DeviceCommandService <<DomainService>>
                class RiskPolicyCommandService <<DomainService>>
                class ActuatorCommandService <<DomainService>>
            }
            package "QueryServices" {
                class DeviceQueryService <<DomainService>>
                class RiskPolicyQueryService <<DomainService>>
            }
        }
    }
}

