@startuml
skinparam packageStyle rectangle

title RestaurantSecurity - Application Layer Structure

package "RestaurantSecurity" {
    package "Domain" {
        package "Model" {
            package "Aggregates" {}
            package "Commands" {}
            package "Queries" {}
        }
        package "Services" {
            package "Builders" {}
        }
    }

    package "Application.Internal" {
        package "CommandServices" {
            class DeviceCommandApplicationService <<ApplicationService>> {
                +handleRegisterSensor(command): void
                +handleUpdateDeviceStatus(command): void
            }
            class RiskPolicyCommandApplicationService <<ApplicationService>> {
                +handleCreateRiskPolicy(command): void
                +handleUpdateThreshold(command): void
            }
            class ActuatorCommandApplicationService <<ApplicationService>> {
                +handleRegisterActuator(command): void
                +handleTriggerAction(command): void
            }
        }
        package "QueryServices" {
            class DeviceQueryApplicationService <<ApplicationService>> {
                +handleGetDeviceById(query)
                +handleListDevices(query)
            }
            class RiskPolicyQueryApplicationService <<ApplicationService>> {
                +handleGetRiskPolicyById(query)
                +handleListRiskPolicies(query)
            }
        }
    }

    package "Infrastructure.Persistence" {
        package "JPA" {
            class DeviceRepository <<Repository>> {
                +save(device): void
                +findById(id)
            }
            class RiskPolicyRepository <<Repository>> {
                +save(policy): void
                +findById(id)
            }
            class MeasureThresholdRepository <<Repository>> {
                +save(threshold): void
                +findByRiskPolicyId(id)
            }
        }
    }
}

