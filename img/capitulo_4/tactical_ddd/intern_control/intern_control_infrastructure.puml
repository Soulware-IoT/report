@startuml
skinparam packageStyle rectangle

title InternControl - Infrastructure Layer Structure

package "InternControl" {
    package "Infrastructure.Persistence" {
        package "JPA" {
            package "Entities" {
                class ControlProcessEntity <<JpaEntity>> {
                    +id: long
                    +name: string
                }
                class RecordTemplateEntity <<JpaEntity>> {
                    +id: long
                    +templateName: string
                }
                class RecordTemplateVersionEntity <<JpaEntity>> {
                    +id: long
                    +version: number
                }
                class TemplateFieldEntity <<JpaEntity>> {
                    +id: long
                    +fieldName: string
                }
                class RecordEntity <<JpaEntity>> {
                    +id: long
                    +status: string
                }
                class RecordValueEntity <<JpaEntity>> {
                    +id: long
                    +value: string
                }
            }
            package "Mappers" {
                class ControlProcessMapper <<Mapper>> {
                    +toDomain(entity)
                    +toEntity(aggregate)
                }
                class RecordTemplateMapper <<Mapper>> {
                    +toDomain(entity)
                    +toEntity(aggregate)
                }
                class RecordMapper <<Mapper>> {
                    +toDomain(entity)
                    +toEntity(aggregate)
                }
            }
            package "Repositories" {
                class JpaControlProcessRepository <<JpaRepository>> {
                    +save(entity): void
                    +findById(id)
                }
                class JpaRecordTemplateRepository <<JpaRepository>> {
                    +save(entity): void
                    +findById(id)
                }
                class JpaRecordRepository <<JpaRepository>> {
                    +save(entity): void
                    +findById(id)
                }
            }
        }
    }

    package "Domain" {
        package "Model" {
            package "Aggregates" {}
            package "Entities" {}
            package "ValueObjects" {}
        }
    }

    package "Application.Internal" {
        package "CommandServices" {}
        package "QueryServices" {}
    }
}

