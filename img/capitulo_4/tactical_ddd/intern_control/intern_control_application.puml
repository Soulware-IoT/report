@startuml
skinparam packageStyle rectangle

title InternControl - Application Layer Structure

package "InternControl" {
    package "Domain" {
        package "Model" {
            package "Aggregates" {}
            package "Commands" {}
            package "Queries" {}
        }
        package "Services" {}
    }

    package "Application.Internal" {
        package "CommandServices" {
            class ControlProcessCommandApplicationService <<ApplicationService>> {
                +handleCreateControlProcess(command): void
                +handleChangeProcessStatus(command): void
            }
            class RecordTemplateCommandApplicationService <<ApplicationService>> {
                +handleCreateTemplate(command): void
                +handlePublishTemplateVersion(command): void
            }
            class RecordCommandApplicationService <<ApplicationService>> {
                +handleRegisterRecord(command): void
                +handleChangeRecordStatus(command): void
            }
        }
        package "QueryServices" {
            class ControlProcessQueryApplicationService <<ApplicationService>> {
                +handleGetControlProcessById(query)
                +handleListControlProcesses(query)
            }
            class RecordTemplateQueryApplicationService <<ApplicationService>> {
                +handleGetTemplateById(query)
                +handleListTemplates(query)
            }
            class RecordQueryApplicationService <<ApplicationService>> {
                +handleGetRecordById(query)
                +handleListRecords(query)
            }
        }
    }

    package "Infrastructure.Persistence" {
        package "JPA" {
            class ControlProcessRepository <<Repository>> {
                +save(controlProcess): void
                +findById(id)
            }
            class RecordTemplateRepository <<Repository>> {
                +save(template): void
                +findById(id)
            }
            class RecordRepository <<Repository>> {
                +save(record): void
                +findById(id)
            }
        }
    }
}

