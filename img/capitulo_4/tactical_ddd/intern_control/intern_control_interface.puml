@startuml
skinparam packageStyle rectangle

title InternControl - Interface Layer Structure

package "InternControl" {
    package "Interfaces.Rest" {
        package "Controllers" {
            class ControlProcessController <<Controller>> {
                +createControlProcess(resource)
                +changeProcessStatus(id, resource)
            }
            class RecordTemplateController <<Controller>> {
                +createTemplate(resource)
                +publishTemplateVersion(id, resource)
            }
            class RecordController <<Controller>> {
                +registerRecord(resource)
                +changeRecordStatus(id, resource)
                +getRecordById(id)
            }
        }
        package "Transform" {
            class ControlProcessResourceAssembler <<Assembler>> {
                +toResource(aggregate)
                +toEntity(resource)
            }
            class RecordTemplateResourceAssembler <<Assembler>> {
                +toResource(aggregate)
                +toEntity(resource)
            }
            class RecordResourceAssembler <<Assembler>> {
                +toResource(aggregate)
                +toEntity(resource)
            }
        }
        package "Resources" {
            class CreateControlProcessResource <<Resource>> {
                -ControlProcessName name
                -ProcessStatus status
                -List<RecordTemplate> templates
            }
            class ChangeControlProcessStatusResource <<Resource>> {
                -ProcessStatus status
            }
            class CreateRecordTemplateResource <<Resource>> {
                -TemplateName name
                -List<RecordTemplateVersion> versions
            }
            class PublishTemplateVersionResource <<Resource>> {
                -VersionNumber version
                -CreatedAt createdAt
                -List<TemplateField> fields
            }
            class RegisterRecordResource <<Resource>> {
                -RecordTemplateVersionId templateVersionId
                -RegisteredAt registeredAt
                -RecordStatus status
                -List<RecordValue> values
            }
            class ChangeRecordStatusResource <<Resource>> {
                -RecordStatus status
            }
            class ControlProcessResource <<Resource>> {
                -ControlProcessId id
                -ControlProcessName name
                -ProcessStatus status
                -List<RecordTemplate> templates
            }
            class RecordTemplateResource <<Resource>> {
                -RecordTemplateId id
                -TemplateName name
                -List<RecordTemplateVersion> versions
            }
            class RecordResource <<Resource>> {
                -RecordId id
                -RecordTemplateVersionId templateVersionId
                -RegisteredAt registeredAt
                -RecordStatus status
                -List<RecordValue> values
            }
        }
    }
}

